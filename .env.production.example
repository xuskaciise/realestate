# Copy to `.env` on the VPS (Docker Compose reads `.env` for variable substitution and the app service).
# Never commit the real `.env` file.
#
# PostgreSQL (Docker service `db` — use hostname `db` and port `5432` in DATABASE_URL from inside the stack)
POSTGRES_USER=realestate_app
# Use a long random password; if it contains @ : / # etc., URL-encode it in DATABASE_URL
POSTGRES_PASSWORD=change_me_to_a_long_random_secret
POSTGRES_DB=realestate
# Host port for optional host-side tools / backups (maps to container 5432, loopback only)
POSTGRES_HOST_PORT=5433

# Prisma — must use Docker network hostname `db` and internal port 5432
# Example: postgresql://realestate_app:ENCODED_PASSWORD@db:5432/realestate?schema=public
DATABASE_URL=postgresql://realestate_app:change_me_to_a_long_random_secret@db:5432/realestate?schema=public

# Next.js public (required at **docker build** time — pass the same values in compose build args / .env)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_UPLOADTHING_APP_ID=

# Server-only secrets
UPLOADTHING_SECRET=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: strict | lax (default lax). Use strict in production if all admin use same-site HTTPS.
SESSION_COOKIE_SAME_SITE=lax

# Optional legacy Mongo helpers in repo (not used by Prisma API routes). Remove if unused.
# MONGODB_URI=

# Optional: reserve for signed sessions / future JWT APIs (not required by current cookie session)
# AUTH_SECRET=
# JWT_SECRET=
